# Kopier denne filen til intake-secrets.env og fyll inn dine NYE nøkler
# (regenerer både Halo Client Secret og Mailgun API key først, siden de ble delt i chat)

HALO_CLIENT_ID=44df393f-a87a-4bbd-be75-a253c8ee3f35
HALO_CLIENT_SECRET=lim_inn_ny_secret_her
MAILGUN_API_KEY=lim_inn_ny_mailgun_key_her

# Cloudflare Turnstile secret (server-side verifisering av intake-skjemaet)
# Public site key står i HTML-koden — secret skal kun bo her.
# Hent fra https://dash.cloudflare.com/?to=/:account/turnstile
TURNSTILE_SECRET=lim_inn_turnstile_secret_her

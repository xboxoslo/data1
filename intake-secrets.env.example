# intake-secrets.env — kun for lokal dev (gitignored, aldri commit)
#
# Du trenger IKKE denne filen hvis du bruker Azure Key Vault (anbefalt — se under).
# Kun behold en lokal kopi hvis du eksplisitt vil overstyre Azure-verdiene.
#
# ───── Anbefalt: Azure Key Vault (lokal dev) ─────
# 1. Installer Azure CLI: https://aka.ms/installazurecliwindows
# 2. `az login`  (én gang per PC)
# 3. `python intake-server.py`  — secrets hentes automatisk
#
# Vault-mapping (se AZURE_SECRETS i intake-server.py):
#   HALO_CLIENT_ID      → micronet-data1-kv   / Halo-Client-Id
#   HALO_CLIENT_SECRET  → micronet-data1-kv   / Halo-Client-Secret
#   TURNSTILE_SECRET    → micronet-data1-kv   / Turnstile-Secret
#   MAILGUN_API_KEY     → micronet-shared-kv  / Mailgun-Api-Key
#
# ───── Railway-prod ─────
# Secrets settes som env vars i Railway-prosjektets Variables-fane.
# intake-server.py prøver env vars FØRST — så prod bruker aldri Azure.
#
# ───── Fallback: lokal .env-fil ─────
# Hvis du virkelig vil ha en .env-fil (f.eks. for å overstyre én verdi midlertidig),
# kopier denne fila til intake-secrets.env og fyll inn verdiene.

HALO_CLIENT_ID=
HALO_CLIENT_SECRET=
MAILGUN_API_KEY=
TURNSTILE_SECRET=
